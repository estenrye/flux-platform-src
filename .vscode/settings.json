{
  "terminal.integrated.defaultProfile.linux": "bash (venv)",
  "terminal.integrated.profiles.linux": {
    "bash (venv)": {
      "path": "bash",
      "args": ["--init-file", "./.bin/.bashrc"]
    }
  },
  "terminal.integrated.defaultProfile.osx": "bash (venv)",
  "terminal.integrated.profiles.osx": {
    "bash (venv)": {
      "path": "bash",
      "args": ["--init-file", "./.bin/.bashrc"]
    }
  },
  "chat.tools.terminal.autoApprove": {
    "make": true,
    "kubectl get": true,
    "kubectl describe": true,
    "kubectl logs": true,
    "/^kubectl get daemonset -n cert-manager cert-manager-csi-driver-spiffe-driver -o jsonpath='\\{\\.spec\\.template\\.spec\\.volumes\\}' \\| python3 -m json\\.tool$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^kubectl get daemonset -n cert-manager cert-manager-csi-driver-spiffe-driver -o jsonpath='\\{\\.spec\\.template\\.spec\\.containers\\[\\*\\]\\.args\\}' \\| python3 -m json\\.tool$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "kubectl exec": true,
    "kubectl debug": true,
    "kubectl rollout": true,
    "kubectl api-resources": true
  }
}