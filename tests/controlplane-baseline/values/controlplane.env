# Controlplane baseline values (M1 design §9).
# Sourced by .bin/run-controlplane-baseline.sh and read by suite scripts.
CLUSTER_NAME=controlplane

# ULA-internal LoadBalancer VIP pool (site-stable; never renumbers).
ULA_VIP_PREFIX=fd97:45c2:b3a1:100:ffff

# Calico IPPool name for internet-facing GUA VIPs; the pool CIDR itself is
# renumber-exposed, so suites select by pool name and assert non-membership
# of the ULA prefix rather than hardcoding the GUA prefix.
GUA_VIP_POOL=lb-ingress-gua

# NAT64 well-known prefix (RFC 6052) — synthesized AAAA answers land here.
NAT64_PREFIX=64:ff9b

# A destination that publishes NO AAAA records, so reaching it proves the
# DNS64+NAT64 path end to end.
V4ONLY_HOST=github.com

# A destination with native AAAA and a valid certificate.
V6_HOST=one.one.one.one

# StorageClasses under test.
SC_ISCSI=truenas-iscsi
SC_NFS=truenas-nfs
