# Platform baseline values: crossplane (Rackspace Spot control plane)
# Sourced by .bin/run-platform-baseline.sh and read by suite scripts.
# M2 adds values/controlplane.env with the home lab cluster's values.

CLUSTER_NAME=crossplane

# AUDIT FINDING (2026-07-11): ADR-16 prescribes trust domain
# crossplane.rye.ninja for this cluster, but csi-driver-spiffe runs with
# --trust-domain=cluster.local and the delegated zone claim surfaces the
# same. The baseline asserts reality; the correct trust domain ships with
# the new controlplane cluster in M2 (changing it here would restart every
# SVID-mounted pod weeks before decommission).
TRUST_DOMAIN=cluster.local

STEP_CA_URL=https://ca.crossplane.rye.ninja
# Pinned root CA fingerprint - this value must NOT change across the M2
# migration (fleet trust anchor). Recorded 2026-07-11.
STEP_CA_ROOT_FINGERPRINT=454b03bf485f2a70f84b6c290e3ff3eaaef30ef192822c5f69d8c593f7635add
# The public CA endpoint is flaky on Spot (observed 25% availability in a
# 60s sample, 2026-07-11; envoy-gateway controller logged 413 restarts in
# 47h; TLS handshake timeouts in multi-minute windows); the suite retries.
# Success on any attempt gates; needing >1 attempt is advisory output.
STEP_CA_HEALTH_RETRIES=20

# tests/step-ca/external exercises the public CA path end-to-end. On Spot it
# is quarantined to ADVISORY (reported, non-gating) because the public path
# has sustained outage windows - a platform finding remediated by the M2
# migration, not by tests. Set to "gate" in values/controlplane.env.
STEP_CA_EXTERNAL_GATE=advisory

DELEGATED_ZONE_CLAIM=crossplane-rye-ninja
DELEGATED_ZONE_NAMESPACE=crossplane-controlplane-cluster

FLUX_NAMESPACE=flux-system

EXPECTED_PROVIDERS="crossplane-contrib-provider-upjet-github provider-kubernetes upbound-provider-aws-iam upbound-provider-aws-rolesanywhere upbound-provider-aws-route53 upbound-provider-family-aws wildbitca-provider-cloudflare-dns wildbitca-provider-cloudflare-zone wildbitca-provider-family-cloudflare"
EXPECTED_FUNCTIONS="function-auto-ready function-environment-configs function-go-templating"
EXPECTED_ENVIRONMENT_CONFIGS="platform-cloudflare platform-iam-rolesanywhere"

# 10 managed resources at time of recording; a drop below this suggests
# something was deleted out-of-band.
MIN_MANAGED_RESOURCES=10

CNPG_NAMESPACE=step-ca
CNPG_CLUSTER=step-ca-db
# AUDIT FINDING (2026-07-11): step-ca-db reports 1/2 ready, phase
# "Creating a new replica". Gate is >=1 ready + primary present; full HA
# (ready == instances) is advisory until the replica recovers.
CNPG_MIN_READY=1
