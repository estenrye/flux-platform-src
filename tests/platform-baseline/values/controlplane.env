# Platform baseline values: controlplane (home lab Talos-on-KVM)
# Sourced by .bin/run-platform-baseline.sh and read by suite scripts.
# This file is the M2 acceptance gate: M2 is complete when the runner
# passes twice consecutively with these values
# (docs/superpowers/specs/2026-07-13-m2-migration-design.md, section 7).

CLUSTER_NAME=controlplane

# ADR-16: set before the first SVID is issued; the spiffe/ suite asserts
# the URI SAN carries this domain (the cluster.local drift on Spot must
# not recur here — see the M2 design, section 4.2).
TRUST_DOMAIN=controlplane.rye.ninja

# A3 (M2 design): ca.rye.ninja is born on the new CA; the old
# ca.crossplane.rye.ninja name never moves.
STEP_CA_URL=https://ca.rye.ninja

# Fresh root minted at M2 step 2 (design amendment A1). Record the
# sha256 fingerprint here at generation time; the step-ca suite fails
# loudly until it is set.
STEP_CA_ROOT_FINGERPRINT=6cdc50debddfe67e200a3ef1e18297eece9e9b68ed5bd5036dd1f4d6e211815b

# Tight retry budget: unlike Spot, this endpoint has no known outage
# windows; needing >1 attempt is advisory output worth investigating.
STEP_CA_HEALTH_RETRIES=5

# The external suite gates on this cluster (the Spot advisory quarantine
# was a recorded platform finding remediated by the migration itself).
STEP_CA_EXTERNAL_GATE=gate

# New claim authored at M2 step 7; update the namespace if the authored
# claim uses a different one.
DELEGATED_ZONE_CLAIM=controlplane-rye-ninja
DELEGATED_ZONE_NAMESPACE=controlplane-cluster

FLUX_NAMESPACE=flux-system

# Same Flux sources as Spot (applications/crossplane-providers/).
EXPECTED_PROVIDERS="crossplane-contrib-provider-upjet-github provider-kubernetes upbound-provider-aws-iam upbound-provider-aws-rolesanywhere upbound-provider-aws-route53 upbound-provider-family-aws wildbitca-provider-cloudflare-dns wildbitca-provider-cloudflare-zone wildbitca-provider-family-cloudflare"
EXPECTED_FUNCTIONS="function-auto-ready function-environment-configs function-go-templating"
EXPECTED_ENVIRONMENT_CONFIGS="platform-cloudflare platform-iam-rolesanywhere"

# Floor covers both phases: during the soak the cluster holds the new
# controlplane.rye.ninja zone stack (~9) plus the migrated
# crossplane.rye.ninja stack (~9, deleted at decommission). 9 is the
# post-decommission steady state; a drop below it means out-of-band
# deletion.
MIN_MANAGED_RESOURCES=9

CNPG_NAMESPACE=step-ca
CNPG_CLUSTER=step-ca-db
# Fresh 3-instance cluster (design A2): full HA gates from day one — no
# inherited degradation advisory here.
CNPG_MIN_READY=3
